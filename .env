# ============================================================
# 市场情绪分析系统 - 环境变量配置
# Market Sentiment Analysis System - Environment Configuration
# ============================================================

# ============================================================
# 数据库配置 (Database Configuration)
# ============================================================

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=market_sentiment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse 配置
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=market_sentiment
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse123

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# 消息队列配置 (Message Queue Configuration)
# ============================================================

# Kafka 配置
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_RAW=raw-news
KAFKA_TOPIC_SENTIMENT=sentiment-news

# Zookeeper 配置 (内部使用)
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# ============================================================
# AI/ML 配置 (AI/ML Configuration)
# ============================================================

# Moonshot/Kimi API 配置
# ✅ 已自动配置
KIMI_API_KEY=sk-u93xdxcXL45BMLPvZI3ZCtsjyCyqdrVbDShrXTs1ErTYNQNI
KIMI_API_URL=https://api.moonshot.cn/v1
NLP_MODEL=moonshot-v1-8k

# ============================================================
# 数据采集配置 (Data Collection Configuration)
# ============================================================

# 默认 RSS 数据源
RSS_FEED_URL=https://36kr.com/feed
COLLECT_INTERVAL=300

# 支持的数据源 (逗号分隔)
DATA_SOURCES=36kr,caixin

# 采集超时设置 (秒)
COLLECT_TIMEOUT=30
COLLECT_RETRY_COUNT=3

# ============================================================
# 服务配置 (Service Configuration)
# ============================================================

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# Web 前端配置
WEB_PORT=3000
WEB_API_URL=http://localhost:8000

# NLP 服务配置
NLP_BATCH_SIZE=10
NLP_MAX_RETRIES=3
NLP_RETRY_DELAY=2

# 聚合服务配置
AGGREGATION_WINDOW_HOURS=24
AGGREGATION_INTERVAL_MINUTES=60

# 定时任务配置
DAILY_REPORT_TIME=08:00
CLEANUP_SCHEDULE=0 2 * * *

# ============================================================
# 监控与日志 (Monitoring & Logging)
# ============================================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 是否开启 JSON 格式日志
LOG_JSON_FORMAT=true

# 应用环境: development, staging, production
APP_ENV=production

# ============================================================
# 安全与认证 (Security & Authentication)
# ============================================================

# JWT 密钥 (生产环境请使用强密码)
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# API 密钥 (用于服务间认证)
API_KEY=your-internal-api-key

# ============================================================
# 数据保留策略 (Data Retention Policy)
# ============================================================

# 原始数据保留天数
RAW_DATA_RETENTION_DAYS=90

# 聚合数据保留天数
AGGREGATED_DATA_RETENTION_DAYS=365

# 日志保留天数
LOG_RETENTION_DAYS=30

# ============================================================
# 性能调优 (Performance Tuning)
# ============================================================

# 数据库连接池配置
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=30

# Kafka 配置
KAFKA_PRODUCER_ACKS=all
KAFKA_CONSUMER_GROUP=market-sentiment-group

# ============================================================
# 通知配置 (Notifications)
# ============================================================

# 邮件通知配置 (可选)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Webhook 配置 (可选)
# WEBHOOK_URL=

# ============================================================
# 外部服务配置 (External Services)
# ============================================================

# 可选: 其他数据源 API
# TUSHARE_API_TOKEN=
# ALPHA_VANTAGE_API_KEY=

# ============================================================
# Docker 配置 (Docker Configuration)
# ============================================================

# Docker 镜像标签
IMAGE_TAG=latest

# 资源限制
COMPOSE_PROJECT_NAME=market-sentiment

# 数据卷路径 (可选，用于挂载到宿主机)
# POSTGRES_DATA_PATH=./data/postgres
# REDIS_DATA_PATH=./data/redis
# CLICKHOUSE_DATA_PATH=./data/clickhouse
