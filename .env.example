# ============================================================
# 市场情绪分析系统 - 环境变量配置示例
# Market Sentiment Analysis System - Environment Configuration Example
# ============================================================

# ============================================================
# 数据库配置 (Database Configuration)
# ============================================================

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=market_sentiment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse 配置
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=market_sentiment
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_this_password

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# AI/ML 配置 (AI/ML Configuration)
# ============================================================

# Moonshot/Kimi API 配置 (必须配置)
KIMI_API_KEY=your-moonshot-api-key-here
KIMI_API_URL=https://api.moonshot.cn/v1
NLP_MODEL=moonshot-v1-8k

# ============================================================
# 数据采集配置 (Data Collection Configuration)
# ============================================================

# 默认 RSS 数据源
RSS_FEED_URL=https://36kr.com/feed
COLLECT_INTERVAL=300

# ============================================================
# 服务配置 (Service Configuration)
# ============================================================

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Web 前端配置
WEB_PORT=3000
WEB_API_URL=http://localhost:8000

# ============================================================
# 安全与认证 (Security & Authentication)
# ============================================================

# JWT 密钥 (生产环境请使用强密码)
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# API 密钥 (用于服务间认证)
API_KEY=your-internal-api-key

# ============================================================
# 数据保留策略 (Data Retention Policy)
# ============================================================

# 原始数据保留天数
RAW_DATA_RETENTION_DAYS=90

# ============================================================
# 性能调优 (Performance Tuning)
# ============================================================

# 数据库连接池配置
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5

# ============================================================
# Docker 配置 (Docker Configuration)
# ============================================================

COMPOSE_PROJECT_NAME=market-sentiment
